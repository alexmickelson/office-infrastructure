{
  "version": "0.0.1",
  "services": {
    "svc:openwebui": {
      "tcp": {
        "443": {
          "https": true
        }
      },
      "web": {
        "${TS_CERT_DOMAIN}:443": {
          "handlers": {
            "/": {
              "proxy": "http://127.0.0.1:8080"
            }
          }
        }
      },
      "funnel": {
        "${TS_CERT_DOMAIN}:443": true
      }
    },

    "svc:grafana": {
      "tcp": {
        "3000": {
          "https": true
        }
      },
      "web": {
        "${TS_CERT_DOMAIN}:3000": {
          "handlers": {
            "/": {
              "proxy": "http://host.docker.internal:3000"
            }
          }
        }
      }
    },

    "svc:prometheus": {
      "tcp": {
        "9090": {
          "https": true
        }
      },
      "web": {
        "${TS_CERT_DOMAIN}:9090": {
          "handlers": {
            "/": {
              "proxy": "http://host.docker.internal:9090"
            }
          }
        }
      }
    },

    "svc:llama": {
      "tcp": {
        "9292": {
          "https": true
        }
      },
      "web": {
        "${TS_CERT_DOMAIN}:9292": {
          "handlers": {
            "/": {
              "proxy": "http://127.0.0.1:8082"
            }
          }
        }
      }
    }
  }
}