{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "America/Denver",
  "labels": ["dependencies"],
  "minimumReleaseAge": "2 days",
  "automerge": true,
  "commitMessagePrefix": "⬆️",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "includePaths": ["ai-office-server/**"],
  "docker-compose": {
    "enabled": true,
    "managerFilePatterns": ["/ai-office-server/docker-compose\\.yml$/"]
  },
  "kubernetes": {
    "enabled": true,
    "managerFilePatterns": ["/ai-office-server/.*\\.ya?ml$/"]
  },
  "argocd": {
    "enabled": true,
    "managerFilePatterns": ["/ai-office-server/kubernetes/argocd/.*\\.ya?ml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update container images embedded in Argo CD kustomization patches",
      "managerFilePatterns": [
        "/ai-office-server/kubernetes/argocd/.*/kustomization\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s+(?<depName>[^:@\\s]+(?:/[^:@\\s]+)+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Group all Docker images together",
      "groupName": "Docker Images",
      "matchDatasources": ["docker"],
      "automerge": true
    },
    {
      "description": "Group all Helm charts together",
      "groupName": "Helm Charts",
      "matchDatasources": ["helm"]
    },
    {
      "description": "Skip minimum release age for internal images",
      "minimumReleaseAge": "0 days",
      "matchPackageNames": ["/pantheon/", "/discord-bot/", "/snow-se-tools/"]
    },
    {
      "description": "Pin digest for production images",
      "matchDatasources": ["docker"],
      "pinDigests": true,
      "matchPackageNames": [
        "/ghcr\\.io/open-webui/open-webui/",
        "/ghcr\\.io/alexmickelson//",
        "/alexmickelson//"
      ]
    },
    {
      "description": "No automerge for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Require manual approval for Helm chart major updates",
      "matchDatasources": ["helm"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Ignore sealed-secrets Helm chart (lookup fails)",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["sealed-secrets"],
      "enabled": false
    }
  ]
}
