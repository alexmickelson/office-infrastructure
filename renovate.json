{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "America/Denver",
  "labels": ["dependencies"],
  "minimumReleaseAge": "2 days",
  "automerge": true,
  "commitMessagePrefix": "⬆️",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "includePaths": ["ai-office-server/**"],
  "docker-compose": {
    "enabled": true,
    "managerFilePatterns": ["/ai-office-server/docker-compose\\.yml$/"]
  },
  "kubernetes": {
    "enabled": true,
    "managerFilePatterns": ["/ai-office-server/.*\\.ya?ml$/"]
  },
  "argocd": {
    "enabled": true,
    "managerFilePatterns": ["/ai-office-server/kubernetes/argocd/.*\\.ya?ml$/"]
  },
  "packageRules": [
    {
      "description": "Group all Docker images together",
      "groupName": "Docker Images",
      "matchDatasources": ["docker"],
      "excludePackageNames": ["/ghcr\\.io\/alexmickelson\/.*/"],
      "automerge": true
    },
    {
      "description": "Group all Helm charts together",
      "groupName": "Helm Charts",
      "matchDatasources": ["helm"]
    },
    {
      "description": "Skip minimum release age for internal images",
      "matchDatasources": ["docker"],
      "minimumReleaseAge": "0 days",
      "groupName": "Internal Docker Images",
      "groupSlug": "internal-docker-images",
      "matchPackageNames": [
        "ghcr.io/alexmickelson/pantheon-gateway",
        "ghcr.io/alexmickelson/discord-bot",
        "ghcr.io/alexmickelson/snow-se-tools",
        "/(^|\\/)pantheon-gateway$/",
        "/(^|\\/)discord-bot$/",
        "/(^|\\/)snow-se-tools$/"
      ]
    },
    {
      "description": "Pin digest for production images",
      "matchDatasources": ["docker"],
      "pinDigests": true,
      "matchPackageNames": [
        "/ghcr\\.io/open-webui/open-webui/",
        "/ghcr\\.io/alexmickelson//",
        "/alexmickelson//"
      ]
    },
    {
      "description": "No automerge for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Require manual approval for Helm chart major updates",
      "matchDatasources": ["helm"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Ignore sealed-secrets Helm chart (lookup fails)",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["sealed-secrets"],
      "enabled": false
    }
  ]
}
