{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "America/Denver",
  "labels": ["dependencies"],
  "minimumReleaseAge": "2 days",
  "prCreation": "immediate",
  "recreateWhen": "always",
  "automerge": true,
  "commitMessagePrefix": "⬆️",
  "includePaths": ["ai-office-server/**"],
  "docker-compose": {
    "enabled": true,
    "managerFilePatterns": ["/ai-office-server/docker-compose\\.yml$/"]
  },
  "kubernetes": {
    "enabled": true,
    "managerFilePatterns": ["/ai-office-server/.*\\.ya?ml$/"]
  },
  "argocd": {
    "enabled": true,
    "managerFilePatterns": ["/ai-office-server/kubernetes/argocd/.*\\.ya?ml$/"]
  },
  "packageRules": [
    // {
    //   "description": "Group Docker image version updates together",
    //   "groupName": "Docker Images",
    //   "matchManagers": ["docker-compose", "dockerfile", "kubernetes"],
    //   "matchDatasources": ["docker"],
    //   "matchUpdateTypes": ["major", "minor", "patch"],
    //   "matchPackageNames": [
    //     "!ghcr.io/alexmickelson/pantheon-gateway",
    //     "!ghcr.io/snowse/discordadminbot",
    //     "!ghcr.io/alexmickelson/snow-se-tools"
    //   ],
    //   "pinDigests": true,
    //   "automerge": true
    // },
    // {
    //   "description": "Group all Argo CD chart updates together",
    //   "groupName": "Argo CD Charts",
    //   "matchManagers": ["argocd"]
    // },
    {
      "description": "Skip minimum release age for internal images",
      "groupName": "Internal Stuff",
      "matchPackageNames": [
        "ghcr.io/alexmickelson/pantheon-gateway",
        "ghcr.io/snowse/discordadminbot",
        "ghcr.io/alexmickelson/snow-se-tools"
      ],
      "minimumReleaseAge": "0 days",
      "pinDigests": true
    }
    // {
    //   "description": "No automerge for major updates",
    //   "matchUpdateTypes": ["major"],
    //   "automerge": false
    // }
  ]
}
