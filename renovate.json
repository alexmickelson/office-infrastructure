{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "America/Denver",
  "labels": ["dependencies"],
  "minimumReleaseAge": "2 days",
  "platformAutomerge": true,
  "commitMessagePrefix": "⬆️",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "ai-server/**",
    "ansible/**",
    "authentication/**",
    "azure/**",
    "data/**",
    "kubernetes/**",
    "monitoring/**",
    "tailscale/**"
  ],
  "includePaths": ["ai-office-server/**"],
  "docker-compose": {
    "enabled": true,
    "managerFilePatterns": [
      "/ai-office-server/docker-compose\\.yml$/"
    ]
  },
  "kubernetes": {
    "enabled": true,
    "managerFilePatterns": [
      "/ai-office-server/.*\\.ya?ml$/"
    ]
  },
  "argocd": {
    "enabled": true,
    "managerFilePatterns": [
      "/ai-office-server/kubernetes/argocd/.*\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Skip minimum release age for pantheon and discord-bot",
      "minimumReleaseAge": null,
      "platformAutomerge": true,
      "automerge": true,
      "matchPackageNames": [
        "/pantheon/",
        "/discord-bot/",
        "/snow-se-tools/"
      ]
    },
    {
      "description": "Group all Docker images together",
      "groupName": "Docker Images",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "!/^postgres$/",
        "!/^nginx$/"
      ]
    },
    {
      "description": "Group all Helm charts together",
      "groupName": "Helm Charts",
      "matchDatasources": ["helm"],
      "automerge": true
    },
    {
      "description": "Auto-merge minor and patch updates for stable packages",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "matchPackageNames": [
        "/^postgres$/",
        "/^nginx$/",
        "/^cloudflare/cloudflared$/"
      ]
    },
    {
      "description": "Separate PRs for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Pin digest for production images",
      "matchDatasources": ["docker"],
      "pinDigests": true,
      "matchPackageNames": [
        "/ghcr\\.io/open-webui/open-webui/",
        "/ghcr\\.io/alexmickelson//",
        "/alexmickelson//"
      ]
    },

    {
      "description": "Require manual approval for Helm chart major updates",
      "matchDatasources": ["helm"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Ignore sealed-secrets Helm chart (lookup fails)",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["sealed-secrets"],
      "enabled": false
    }
  ]
}
